# Database — local dev points at Homebrew Postgres 15. For Docker use the compose creds:
# DATABASE_URL=postgresql://maridata:maridata@localhost:5432/maridata
DATABASE_URL=postgresql://ritesh5001@localhost:5432/maridata

# API
PORT=4000
# Origin allowed by CORS (the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Auth (single admin). Generate the hash with: npm run hash-password -- 'your-password'
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-long-random-string

# Public read-only API (/public/v1) for third-party platforms.
# One key per consuming platform, comma-separated; empty disables the public API.
# Generate a key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Consumers send it as: Authorization: Bearer <key>   (or  X-API-Key: <key>)
API_KEYS=
# Per-IP rate limit for the public API.
PUBLIC_RATE_WINDOW_MS=60000
PUBLIC_RATE_MAX=60

# In production set NODE_ENV=production (enables secure cookies) and use a strong,
# random JWT_SECRET plus a real ADMIN_PASSWORD_HASH.
# NODE_ENV=production

# Frontend (Vite)
VITE_API_URL=http://localhost:4000
